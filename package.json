{
  "name": "merkato_store_api_node",
  "version": "1.0.0",
  "description": "Merkato Store REST API — Express + Prisma + PostgreSQL",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "predev": "node scripts/ensureDatabase.js",
    "dev": "nodemon server.js",
    "db:ensure": "node scripts/ensureDatabase.js",
    "db:migrate": "npm run db:ensure && prisma migrate dev",
    "db:setup": "npm run db:ensure && prisma migrate dev --name init && npm run seed",
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.22.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "prisma": "^5.14.0"
  }
}
